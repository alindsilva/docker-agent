# cagent Development Environment Configuration
# Copy this file to .env.dev and fill in your actual values
# DO NOT commit .env.dev to version control!

# ==============================================
# cagent API Configuration
# ==============================================
LISTEN_ADDR=":8080"
CAGENT_API_TOKEN="cc9f90c61c02c40fd9da01f1473588e60047e6aee04171377f1622c6dc3653ec"

# ==============================================
# Database Paths (Local Development)
# ==============================================
ALERTS_DB_PATH="./var/dev/alerts.db"
SESSIONS_DB_PATH="./var/dev/trading_sessions.db"

# ==============================================
# Slack Configuration
# ==============================================
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token-here"
SLACK_SIGNING_SECRET="your-slack-signing-secret-here"
SLACK_STATE_HMAC_SECRET="96765c46b05250de4d49e9ec4b64cb1ecc213dd0ef5eaa13705f1be14fbe51bf"
SLACK_CHANNEL_ID="C0123456789"  # Your private approval channel ID

# ==============================================
# TradingView Configuration
# ==============================================
# Create a random token for TradingView to send in Authorization header
# Generate with: openssl rand -hex 32
TRADINGVIEW_TOKEN="b9d98600f864fb7da4cdc5e14e4725ca6dcd12fcc656496af314eb7c9ad9ee0c"

# Optional: HMAC signature verification (leave empty if not using)
TRADINGVIEW_HMAC_SECRET=""

# ==============================================
# cagent Settings
# ==============================================
TELEMETRY_ENABLED=false
CAGENT_HIDE_TELEMETRY_BANNER=true
